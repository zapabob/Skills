{
  "name": "@zapabob/skills",
  "version": "0.1.0",
  "description": "Portable multi-agent skill catalog and installer for Codex, ClaudeCode, Cursor, Antigravity, and Openclaw.",
  "type": "module",
  "bin": {
    "agent-skill-unifier": "./bin/agent-skill-unifier.js"
  },
  "files": [
    "bin",
    "lib",
    "registry",
    "README.md"
  ],
  "scripts": {
