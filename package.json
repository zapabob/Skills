    "url": "https://github.com/zapabob/Skills/issues"
  },
  "author": "zapabob",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "skills",
    "codex",
    "cursor",
    "claude",
    "openclaw",
    "antigravity",
    "claudecode",
    "skill-catalog",
    "agent-skills",
    "npx"
